DATABASE_URL=postgres://app_user:app_password@127.0.0.1:5432/simple_todo_list

# Optional alternative to DATABASE_URL:
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=simple_todo_list
# PGUSER=app_user
# PGPASSWORD=app_password

# Supabase (Vercel) — TLS is required, so keep ?sslmode=require on the URL.
# Use the pooled connection (port 6543) for the running app:
# DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
# Use the direct connection (port 5432) only for running migrations:
# DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# NEXT_TODO_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_NEXT_TODO_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_NEXT_TODO_SUPABASE_URL=
# NEXT_TODO_POSTGRES_DATABASE="postgres"
# NEXT_TODO_POSTGRES_HOST=
# NEXT_TODO_POSTGRES_PASSWORD=
# NEXT_TODO_POSTGRES_PRISMA_URL=
# NEXT_TODO_POSTGRES_URL=
# NEXT_TODO_POSTGRES_URL_NON_POOLING=
# NEXT_TODO_POSTGRES_USER="postgres"
# NEXT_TODO_SUPABASE_ANON_KEY=
# NEXT_TODO_SUPABASE_JWT_SECRET=
# NEXT_PUBLIC_NEXT_TODO_SUPABASE_PUBLISHABLE_KEY=
# NEXT_TODO_SUPABASE_SECRET_KEY=
# NEXT_TODO_SUPABASE_SERVICE_ROLE_KEY=
# NEXT_PUBLIC_NEXT_TODO_SUPABASE_URL=